RewriteEngine On
RewriteBase /

# Force HTTPS (uncomment if SSL is active)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except for directories)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# --- Clean URLs: strip .php extension ---
# Redirect /page.php to /page (external redirect)
RewriteCond %{THE_REQUEST} \s/([^?]*?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# --- Clean URLs: strip .html extension ---
# Redirect /page.html to /page (external redirect)
RewriteCond %{THE_REQUEST} \s/([^?]*?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# --- Internal rewrites ---
# Don't rewrite real files, directories, or api/ paths
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Skip rewriting for api/ (they keep .php extension internally)
RewriteRule ^api/ - [L]

# Try .php first, then .html
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Custom 404
ErrorDocument 404 /404.html
